{
  "name": "arabic-phonics-next-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "validate:dev-isolation": "node scripts/validate-dev-isolation.mjs",
    "validate:foundation": "npm run lint && npm run typecheck && npm run validate:dev-isolation && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "framer-motion": "^12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@prisma/config": "^7.8.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "^5.22.0",
    "typescript": "5.7.3"
  },
  "allowScripts": {
    "prisma": true,
    "@prisma/engines": true,
    "@prisma/client": true,
    "sharp": true,
    "unrs-resolver": true,
    "foreground-child": true
  }
}
